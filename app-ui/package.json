{
  "name": "crate-lynx-ui",
  "private": true,
  "license": "MIT",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "codegen": "../scripts/generate-types.sh",
    "codegen:check": "node ./scripts/check-generated-types.mjs",
    "lint": "eslint .",
    "test": "node --require ./scripts/fix-localhost.cjs ./node_modules/vitest/vitest.mjs run --exclude 'e2e/**'",
    "test:browser": "npm run build && playwright test",
    "test:browser:ci": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@catppuccin/tailwindcss": "^1.0.0",
    "@eslint/js": "^9.12.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.7.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.8.1",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
