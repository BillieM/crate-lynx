{
  "name": "crate-lynx-ui",
  "private": true,
  "license": "MIT",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "codegen": "../scripts/generate-types.sh",
    "codegen:check": "npm run codegen && git -C .. diff --exit-code -- app-ui/src/lib/api-types.ts",
    "lint": "npm run codegen:check && eslint .",
    "test": "node --require ./scripts/fix-localhost.cjs ./node_modules/vitest/vitest.mjs run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.76.1",
    "@tanstack/react-table": "^8.21.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@catppuccin/tailwindcss": "^1.0.0",
    "@eslint/js": "^9.12.0",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.8.1",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
