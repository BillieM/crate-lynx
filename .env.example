# Copy this file to `.env` before starting the stack.

# App secrets and local paths
TOKEN_ENCRYPTION_KEY=replace-me-with-a-fernet-key
LIBRARY_ROOT=/absolute/path/to/your/music-library
M3U_OUTPUT_DIR=/absolute/path/to/m3u-output

# Database bootstrap values used by both Postgres and the app container
POSTGRES_DB=crate_lynx
POSTGRES_USER=crate_lynx
POSTGRES_PASSWORD=change-me
