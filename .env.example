# Copy this file to `.env` before starting the stack.

# App secrets and local paths
# Generate with:
# python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
TOKEN_ENCRYPTION_KEY=
LIBRARY_ROOT=/nas/media/music
LOCAL_DEDUPE_QUARANTINE_ROOT=/nas/cratelynx/dedupe-quarantine
BEETS_LIBRARY=/data/beets/library.db
BEETS_IMPORT_LOCK_PATH=/data/beets/library.db.import.lock
CRATE_LYNX_STAGING_DIR=/nas/cratelynx/staging
INGESTION_ROOT=/nas/cratelynx/music-in

# Bounded worker concurrency (preflight rejects values outside these ranges)
INGESTION_STABILITY_WORKERS=4
INGESTION_WORKER_COUNT=1
SONIC_WORKER_COUNT=2

# Optional reverse-proxy hostname used by the Traefik labels in docker-compose.yml
CRATELYNX_HOST=cratelynx.local

# Published host ports bind to localhost by default. Use 0.0.0.0 only on a trusted LAN.
UI_BIND_HOST=127.0.0.1
APP_BIND_HOST=127.0.0.1
DB_BIND_HOST=127.0.0.1
REDIS_BIND_HOST=127.0.0.1

# Host paths mounted into the app container by docker-compose.yml
NAS_DATA_HOST_PATH=/mnt/nas_data
APP_DATA_HOST_PATH=/docker/appdata/cratelynx

# Database bootstrap values used by both Postgres and the app container
POSTGRES_DB=crate_lynx
POSTGRES_USER=crate_lynx
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# Optional slskd integration. Leave blank unless slskd is reachable from the app container.
SLSKD_BASE_URL=
SLSKD_API_KEY=
SLSKD_VERIFY_SSL=true
# Numeric Soulseek controls are validated before the app starts.
SLSKD_REQUEST_TIMEOUT_SECONDS=10
SLSKD_SEARCH_TIMEOUT_SECONDS=30
SLSKD_SEARCH_POLL_TIMEOUT_SECONDS=30
SLSKD_SEARCH_POLL_INTERVAL_SECONDS=2
SLSKD_RESPONSE_LIMIT=100
SLSKD_FILE_LIMIT=10000
SLSKD_MAXIMUM_PEER_QUEUE_LENGTH=1000000
SLSKD_MINIMUM_PEER_UPLOAD_SPEED=0
SLSKD_WEBHOOK_TOKEN=
SLSKD_DOWNLOADS_CONTAINER_ROOT=/data/soulseek/downloads
SLSKD_DOWNLOADS_APP_ROOT=/nas/soulseek/downloads
