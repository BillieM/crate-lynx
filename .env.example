# Copy this file to `.env` before starting the stack.

# App secrets and local paths
# Generate with:
# python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
TOKEN_ENCRYPTION_KEY=
LIBRARY_ROOT=/music
BEETS_LIBRARY=/data/beets/library.db
CRATE_LYNX_STAGING_DIR=/tmp/crate-lynx
INGESTION_ROOT=/ingestion
M3U_OUTPUT_DIR=/data/m3u

# Host paths mounted into the app container by docker-compose.yml
INGESTION_HOST_PATH=/srv/mergerfs/hdds/music-in
SOULSEEK_HOST_PATH=/srv/mergerfs/hdds/soulseek/downloads
MUSIC_HOST_PATH=/srv/mergerfs/hdds/media/music
APP_DATA_HOST_PATH=/docker/appdata/cratelynx

# Database bootstrap values used by both Postgres and the app container
POSTGRES_DB=crate_lynx
POSTGRES_USER=crate_lynx
POSTGRES_PASSWORD=change-me
