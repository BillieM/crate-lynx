HOST=http://192.168.0.203:18101
DISPLAY_NAME=My YT Music

# OAuth credentials from Google Cloud Console.
# IMPORTANT: application type must be "TV and Limited Input devices".
# Web or desktop client types will cause HTTP 400 errors on library syncs.
# Steps:
#   1. APIs & Services > Credentials > Create Credentials > OAuth client ID
#   2. Application type: "TV and Limited Input devices"
#   3. Enable YouTube Data API v3 on the project
CLIENT_ID=your-client-id.apps.googleusercontent.com
CLIENT_SECRET=your-client-secret
